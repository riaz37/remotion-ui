# RemotionUI command policy for Codex.
# Keep broad commands in the sandbox; allow common read-only inspections outside it when requested.

prefix_rule(
    pattern = ["git", "status"],
    decision = "allow",
    justification = "Inspecting repository status is safe and commonly needed.",
    match = ["git status", "git status --short --branch"],
)

prefix_rule(
    pattern = ["git", "diff"],
    decision = "allow",
    justification = "Inspecting diffs is safe and commonly needed.",
    match = ["git diff", "git diff --stat"],
)

prefix_rule(
    pattern = ["pnpm", "registry:build"],
    decision = "prompt",
    justification = "Registry generation writes tracked output and should be intentional.",
    match = ["pnpm registry:build"],
)

prefix_rule(
    pattern = ["pnpm", "build"],
    decision = "prompt",
    justification = "Full builds can be expensive and may write build artifacts.",
    match = ["pnpm build"],
)
